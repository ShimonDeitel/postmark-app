// Copy to Secrets.xcconfig (gitignored). `make gen` does this automatically
// if Secrets.xcconfig is missing.
//
// POSTMARK_API_KEY may be left empty for simulator dev: DEBUG builds fall
// back to reading ~/.cache/neverend/openrouter.key on the host Mac.
// Before App Store submission, point POSTMARK_API_ENDPOINT at the thin proxy
// so no key ships in the binary.
//
// Note: xcconfig treats // as a comment start, hence the $() escape in URLs.

POSTMARK_API_KEY =
POSTMARK_API_ENDPOINT = https:/$()/openrouter.ai/api/v1/chat/completions
POSTMARK_MODEL =
